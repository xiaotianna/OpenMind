{
  "name": "openmind-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "OpenMind Desktop Application",
  "scripts": {
    "install:all": "pnpm i -r",
    "dev": "pnpm --filter @openmind/desktop dev",
    "build": "pnpm --filter @openmind/desktop build",
    "build:all": "pnpm -r build",
    "dev:server": "pnpm --filter @openmind/server dev"
  },
  "devDependencies": {
    "typescript": "^5.2.2"
  },
  "dependencies": {
    "@lobehub/fluent-emoji": "^4.1.0",
    "@lobehub/ui": "^5.5.1",
    "antd": "^6.3.3"
  }
}
